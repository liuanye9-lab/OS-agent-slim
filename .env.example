# StableAgent Cloud — 环境配置
# 复制此文件为 .env 并修改

# JWT 签名密钥（生产环境务必修改！）
JWT_SECRET=your-secret-key-change-me

# SaaS 运行模式: local | saas
SAAS_MODE=local

# 数据库路径
DB_PATH=data/stable_agent.sqlite3

# 服务端口
PORT=8000

# CORS 允许的源（多个用逗号分隔）
CORS_ORIGINS=*

# 速率限制
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=60
RATE_LIMIT_TEAM=300
