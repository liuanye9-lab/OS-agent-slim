# Feishu/Lark API credentials (V7.1)
# 复制为 .env 并填入真实凭证
# .env 已加入 .gitignore，不会被提交
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxx

# 飞书审核通知目标（可选）
# FEISHU_CHAT_ID=oc_xxxxxxxx

# LLM API Key — 支持阿里云 DashScope / OpenAI 兼容 API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
STABLE_AGENT_LLM_MODEL=qwen-plus
STABLE_AGENT_ENABLE_REAL_LLM=false

# 本地运行模式 (local / production)
STABLE_AGENT_MODE=local
