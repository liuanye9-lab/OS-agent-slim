classDiagram
    %% ── V5 新增数据模型 (models.py) ──
    class RunContext {
        +str run_id
        +str tool_call_id
        +str trace_id
        +str span_id
        +Optional~str~ parent_span_id
        +str avatar_state
    }

    class StableAgentToolResult {
        +bool ok
        +str run_id
        +str tool_call_id
        +str tool_name
        +Optional~Any~ data
        +str plain_text
        +list~str~ warnings
        +list~str~ next_actions
        +str trace_url
        +bool is_error
    }

    %% ── V4 已有模型 (复用) ──
    class Event {
        +float timestamp
        +str type
        +dict payload
    }

    class TraceSpan {
        +str span_id
        +str run_id
        +Optional~str~ parent_span_id
        +str name
        +str type
        +str status
        +float started_at
        +Optional~float~ ended_at
        +Optional~int~ latency_ms
    }

    class ApprovalRequest {
        +str request_id
        +str run_id
        +str action
        +str risk
        +str reason
        +str status
        +float created_at
        +Optional~float~ resolved_at
    }

    class RunRecord {
        +str run_id
        +str user_task
        +TaskType task_type
        +str status
        +float started_at
        +Optional~float~ ended_at
    }

    %% ── gateway/ 包 ──
    class MCPGateway {
        -ToolRouter _router
        -JSONRPCHandler _jsonrpc
        -ResponseAdapter _adapter
        -RunStore _run_store
        -EventStream _event_stream
        +handle_jsonrpc(request) StreamingResponse
        +handle_sse(run_id) StreamingResponse
        +handle_ws(run_id, websocket) None
    }

    class JSONRPCHandler {
        -ToolRouter _router
        -RunStore _run_store
        +parse_message(body) dict
        +handle_initialize(params) dict
        +handle_tools_list() dict
        +handle_tools_call(params) dict
        -_generate_run_context() RunContext
    }

    class ToolRouter {
        -UnifiedToolRegistry _registry
        -SecurityPolicy _security
        -ApprovalManager _approval
        -EventBus _event_bus
        +route(ctx, tool_name, args) StableAgentToolResult
        -_check_approval(ctx, tool_name, args) None
        -_publish_trace(event_type, ctx, payload) None
    }

    class UnifiedToolRegistry {
        -dict _tools
        +register(name, handler, schema) None
        +lookup(name) ToolHandler
        +call(ctx, name, args) StableAgentToolResult
        +list_tools() list
        -_register_all() None
    }

    class ResponseAdapter {
        +to_mcp_content(result) list~dict~
        +to_jsonrpc_error(code, message) dict
        +to_jsonrpc_result(id, result) dict
    }

    %% ── observation/ 包 ──
    class RunStore {
        -dict _runs
        -dict _events
        -TraceStorage _storage
        +create_run(run_id, user_task) RunRecord
        +get_run(run_id) Optional~RunRecord~
        +add_event(run_id, event) None
        +get_events(run_id, limit) list~Event~
        +update_run_status(run_id, status) None
    }

    class EventStream {
        -EventBus _event_bus
        -dict _subscriptions
        +subscribe(run_id, callback) None
        +unsubscribe(run_id, callback) None
        +publish_to_run(run_id, event) None
        -_on_event(event) None
    }

    class DashboardSync {
        -EventStream _event_stream
        -RunStore _run_store
        -dict _ws_connections
        +connect(run_id, websocket) None
        +disconnect(run_id, websocket) None
        +broadcast_to_run(run_id, message) None
        -_on_run_event(run_id, event) None
    }

    %% ── V4 已有模块 ──
    class EventBus {
        -list _listeners
        -list _events
        -dict _spans
        +subscribe(listener) None
        +unsubscribe(listener) None
        +publish(event) None
        +publish_trace_event(type, ctx, payload) None
        +get_events_by_run(run_id) list
        +start_span(run_id, name, type) TraceSpan
        +end_span(span, status, payload) None
    }

    class SecurityPolicy {
        +classify_command(command) str
        +classify_path(path) str
        +should_require_approval(action, risk, command, path) bool
    }

    class ApprovalManager {
        -dict _requests
        +create_request(run_id, action, risk, reason) ApprovalRequest
        +approve(request_id) ApprovalRequest
        +reject(request_id, reason) ApprovalRequest
        +list_pending() list
        +has_pending_for_run(run_id) bool
    }

    class TraceStorage {
        +save_event(event) None
        +load_events(limit) list
        +save_span(span) None
        +load_spans(run_id, limit) list
    }

    %% ── 关系 ──
    MCPGateway *-- JSONRPCHandler : composes
    MCPGateway *-- ToolRouter : composes
    MCPGateway *-- ResponseAdapter : composes
    MCPGateway --> RunStore : uses
    MCPGateway --> EventStream : uses

    JSONRPCHandler --> ToolRouter : delegates
    JSONRPCHandler --> RunStore : creates runs
    JSONRPCHandler ..> RunContext : generates

    ToolRouter *-- UnifiedToolRegistry : composes
    ToolRouter --> SecurityPolicy : checks risk
    ToolRouter --> ApprovalManager : creates approvals
    ToolRouter --> EventBus : publishes traces
    ToolRouter ..> StableAgentToolResult : returns

    UnifiedToolRegistry ..> RunContext : receives
    UnifiedToolRegistry ..> StableAgentToolResult : returns

    ResponseAdapter ..> StableAgentToolResult : converts

    EventStream --> EventBus : wraps
    EventStream ..> Event : filters by run_id

    RunStore --> TraceStorage : persists
    RunStore ..> RunRecord : manages
    RunStore ..> Event : indexes

    DashboardSync --> EventStream : subscribes
    DashboardSync --> RunStore : queries

    EventBus --> TraceStorage : persists via
    EventBus ..> Event : publishes
    EventBus ..> TraceSpan : manages

    SecurityPolicy ..> ApprovalRequest : informs
    ApprovalManager ..> ApprovalRequest : manages
